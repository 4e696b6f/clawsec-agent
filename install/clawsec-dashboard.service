[Unit]
Description=ClawSec Dashboard (Vite preview) for %i
After=network.target clawsec.service
Wants=clawsec.service

[Service]
Type=simple
User=%i
WorkingDirectory=%h/.openclaw/workspace/clawsec/dashboard
ExecStart=/usr/bin/npm run preview -- --host 127.0.0.1 --port 8081
Restart=always
RestartSec=10
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
